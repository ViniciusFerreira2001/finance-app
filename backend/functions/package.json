{
  "name": "finance-app-functions",
  "description": "Cloud Functions for Finance App backend",
  "scripts": {
    "serve": "npx firebase emulators:start --only functions,firestore,auth",
    "shell": "npx firebase functions:shell",
    "start": "npm run shell",
    "deploy": "npx firebase deploy --only functions,firestore",
    "logs": "npx firebase functions:log",
    "lint": "eslint ."
  },
  "engines": {
    "node": "18"
  },
  "main": "index.js",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.6.0"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0"
  },
  "private": true
}
